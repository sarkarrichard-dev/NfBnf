# Copy to .env and fill in. Never commit .env.

# --- Remote LLM (OpenAI-compatible JSON API) ---
# Works with OpenAI, OpenRouter, Groq, Together, Mistral, many others.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Market / broker APIs (add what you use) ---
# NSE/BSE data vendor, broker, or research API keys go here.
# MARKET_API_KEY=
# MARKET_API_BASE_URL=

# --- DhanHQ data feed (live heatmaps later) ---
# Keep live order placement disabled until paper trading and risk gates pass.
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
DHAN_API_BASE_URL=https://api.dhan.co/v2
DHAN_FEED_URL=wss://api-feed.dhan.co
NBNF_ENABLE_LIVE_TRADING=false

# --- Web desk ---
# Learning state is stored locally in data/nbnf.sqlite (gitignored).
# Run: double-click Start-QuantTape.cmd  (or: nbnf-serve / uvicorn as below)
# python -m uvicorn nbnf.server.app:app --host 127.0.0.1 --port 8000
